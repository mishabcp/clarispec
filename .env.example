# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq AI (primary)
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Google Gemini AI (fallback when Groq is rate-limited)
GEMINI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_SESSION_SECRET=

# Optional: distributed rate limit store (Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TRUST_PROXY_HEADERS=false

# Safety switch for local admin scripts only
ALLOW_PROD_ADMIN_SCRIPTS=false

# Auth debugging (optional)
# Durable step log (sessionStorage + console after redirect): /login?authTrace=1 or NEXT_PUBLIC_AUTH_TRACE=1
NEXT_PUBLIC_AUTH_TRACE=
# Verbose console + 5s pause: /login?authDebug=1 (persists in sessionStorage for the tab). Or NEXT_PUBLIC_DEBUG_AUTH=1
NEXT_PUBLIC_DEBUG_AUTH=
# Server / proxy: log pathname, hasUser, sb-* cookie names, getUser errors (terminal or host logs)
AUTH_DEBUG_PROXY=
