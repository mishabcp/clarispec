# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq AI (primary)
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Google Gemini AI (fallback when Groq is rate-limited)
GEMINI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_SESSION_SECRET=

# Sentry (https://sentry.io) — set NEXT_PUBLIC_SENTRY_DSN in Vercel for client + server
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=
# Production hostname (no protocol) for dropping preview-deployment Flight noise in Sentry; optional if NEXT_PUBLIC_APP_URL is set to prod URL
NEXT_PUBLIC_SENTRY_PRODUCTION_HOST=
# Set true to report every RSC "Connection closed." (no Headless/preview drop)
NEXT_PUBLIC_SENTRY_KEEP_ALL_FLIGHT_ERRORS=
# Source maps + release (Vercel build): create token at https://docs.sentry.io/api/auth/
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Verbose browser console logging for window.error / unhandledrejection (set true on Vercel when debugging)
NEXT_PUBLIC_CLIENT_ERROR_LOGS=false

# Edge/proxy auth: log path, hasUser, sb cookie count (no tokens) → Vercel → Logs → filter [clarispec/proxy-auth]
DEBUG_AUTH_MIDDLEWARE=false

# Optional: distributed rate limit store (Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TRUST_PROXY_HEADERS=false

# Safety switch for local admin scripts only
ALLOW_PROD_ADMIN_SCRIPTS=false
