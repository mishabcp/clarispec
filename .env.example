# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq AI (primary)
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Google Gemini AI (fallback when Groq is rate-limited)
GEMINI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_SESSION_SECRET=

# Optional: distributed rate limit store (Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TRUST_PROXY_HEADERS=false

# Safety switch for local admin scripts only
ALLOW_PROD_ADMIN_SCRIPTS=false

# Auth debugging (optional)
# Verbose (pause + on-page log panel): localStorage.setItem('clarispec_debug_auth','1') then reload, OR:
NEXT_PUBLIC_DEBUG_AUTH=
# Pause duration in ms when verbose (default 5000, max 120000; 0 = skip wait)
NEXT_PUBLIC_AUTH_DEBUG_DELAY_MS=
# Server / proxy: log pathname, hasUser, sb-* cookie names, getUser errors (terminal or host logs)
AUTH_DEBUG_PROXY=
# Optional with verbose only (browser): localStorage.setItem('clarispec_debug_auth_manual','1') — no auto navigation until UI "Continue"
